{
  "suite": "sprint2-validate-build",
  "runner": "dotnet run --no-build --project {suite_dir}/../src/unifocl/unifocl.csproj --",
  "project": "{suite_dir}/../.local/validate-smoke",
  "mode": "project",
  "cases": [
    {
      "id": "validate-asmdef-smoke",
      "description": "validate asmdef runs CLI-side and returns a result (no Assets dir → error or pass)",
      "steps": [
        {
          "cmd": "/validate asmdef",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains_any": ["PASS", "FAIL", "asmdef"] }
          }
        }
      ]
    },
    {
      "id": "validate-asset-refs-needs-daemon",
      "description": "asset-refs without a live Unity daemon reports not running",
      "steps": [
        {
          "cmd": "/validate asset-refs",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains": "daemon not running" }
          }
        }
      ]
    },
    {
      "id": "validate-addressables-needs-daemon",
      "description": "addressables without a live Unity daemon reports not running",
      "steps": [
        {
          "cmd": "/validate addressables",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains": "daemon not running" }
          }
        }
      ]
    },
    {
      "id": "build-snapshot-packages-smoke",
      "description": "build snapshot-packages writes a snapshot file and reports package count",
      "steps": [
        {
          "cmd": "/build snapshot-packages",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains_any": ["snapshot", "package(s)"] }
          }
        }
      ]
    },
    {
      "id": "build-preflight-smoke",
      "description": "build preflight runs without daemon and reports preflight status",
      "steps": [
        {
          "cmd": "/build preflight",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains_any": ["Preflight", "preflight"] }
          }
        }
      ]
    },
    {
      "id": "build-artifact-metadata-no-report",
      "description": "build artifact-metadata without a build report and no daemon reports not running",
      "steps": [
        {
          "cmd": "/build artifact-metadata",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains": "daemon not running" }
          }
        }
      ]
    },
    {
      "id": "build-failure-classify-no-daemon",
      "description": "build failure-classify without a live Unity daemon reports not running",
      "steps": [
        {
          "cmd": "/build failure-classify",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains": "daemon not running" }
          }
        }
      ]
    },
    {
      "id": "build-report-smoke",
      "description": "build report runs and outputs Build Report header",
      "steps": [
        {
          "cmd": "/build report",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains": "Build Report" }
          }
        }
      ]
    }
  ]
}
