{
  "suite": "tag-layer",
  "runner": "dotnet run --no-build --project {suite_dir}/../src/unifocl/unifocl.csproj --",
  "project": "{suite_dir}/../.local/tag-layer-smoke",
  "mode": "project",
  "cases": [
    {
      "id": "tag-no-args-shows-usage",
      "description": "/tag with no subcommand shows usage",
      "steps": [
        {
          "cmd": "/tag",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains": "usage" }
          }
        }
      ]
    },
    {
      "id": "tag-unknown-subcommand-rejected",
      "description": "/tag with unknown subcommand shows error and supported list",
      "steps": [
        {
          "cmd": "/tag bogus",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains": "unknown tag subcommand" }
          }
        }
      ]
    },
    {
      "id": "tag-list-needs-daemon",
      "description": "/tag list without a live Unity daemon reports not running",
      "steps": [
        {
          "cmd": "/tag list",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains": "daemon not running" }
          }
        }
      ]
    },
    {
      "id": "tag-ls-alias-needs-daemon",
      "description": "/tag ls alias also reports daemon not running",
      "steps": [
        {
          "cmd": "/tag ls",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains": "daemon not running" }
          }
        }
      ]
    },
    {
      "id": "tag-add-needs-daemon",
      "description": "/tag add without a live daemon reports not running",
      "steps": [
        {
          "cmd": "/tag add Enemy",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains": "daemon not running" }
          }
        }
      ]
    },
    {
      "id": "tag-add-missing-name",
      "description": "/tag add with no name argument shows usage",
      "steps": [
        {
          "cmd": "/tag add",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains": "usage" }
          }
        }
      ]
    },
    {
      "id": "tag-remove-needs-daemon",
      "description": "/tag remove without a live daemon reports not running",
      "steps": [
        {
          "cmd": "/tag remove Enemy",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains": "daemon not running" }
          }
        }
      ]
    },
    {
      "id": "tag-remove-missing-name",
      "description": "/tag remove with no name argument shows usage",
      "steps": [
        {
          "cmd": "/tag rm",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs[0]": { "$contains": "usage" }
          }
        }
      ]
    },
    {
      "id": "layer-no-args-shows-usage",
