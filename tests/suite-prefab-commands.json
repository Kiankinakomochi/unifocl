{
  "$schema": "../.codex/testcase.schema.json",
  "suite": "prefab-commands",
  "runner": "dotnet run --project {suite_dir}/../src/unifocl/unifocl.csproj --no-build --",
  "project": "{suite_dir}/../.local/compatcheck-benchmark",
  "mode": "project",
  "cases": [
    {
      "id": "bare-prefab-shows-usage",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab",
          "assert": {
            ".status": "success",
            ".data.logs | length": { "$gt": 0 },
            ".data.logs[0]": { "$contains": "usage" }
          }
        }
      ]
    },
    {
      "id": "unknown-subcommand-shows-error",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab nonexistent",
          "assert": {
            ".status": "success",
            ".data.logs | length": { "$gt": 0 },
            ".data.logs[0]": { "$contains": "unknown" }
          }
        }
      ]
    },
    {
      "id": "create-missing-args-shows-usage",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab create",
          "assert": {
            ".status": "success",
            ".data.logs | length": { "$gt": 0 },
            ".data.logs[0]": { "$contains": "usage" }
          }
        }
      ]
    },
    {
      "id": "apply-missing-args-shows-usage",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab apply",
          "assert": {
            ".status": "success",
            ".data.logs | length": { "$gt": 0 },
            ".data.logs[0]": { "$contains": "usage" }
          }
        }
      ]
    },
    {
      "id": "revert-missing-args-shows-usage",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab revert",
          "assert": {
            ".status": "success",
            ".data.logs | length": { "$gt": 0 },
            ".data.logs[0]": { "$contains": "usage" }
          }
        }
      ]
    },
    {
      "id": "unpack-missing-args-shows-usage",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab unpack",
          "assert": {
            ".status": "success",
            ".data.logs | length": { "$gt": 0 },
            ".data.logs[0]": { "$contains": "usage" }
          }
        }
      ]
    },
    {
      "id": "variant-missing-args-shows-usage",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab variant",
          "assert": {
            ".status": "success",
            ".data.logs | length": { "$gt": 0 },
            ".data.logs[0]": { "$contains": "usage" }
          }
        }
      ]
    },
    {
      "id": "create-no-daemon-error",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab create Player Assets/Prefabs/Test.prefab",
          "assert": {
            ".status": "error",
            ".errors | length": { "$gt": 0 },
            ".errors[0].message": { "$contains": "daemon is not attached" }
          }
        }
      ]
    },
    {
      "id": "apply-no-daemon-error",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab apply 3",
          "assert": {
            ".status": "error",
            ".errors | length": { "$gt": 0 },
            ".errors[0].message": { "$contains": "daemon is not attached" }
          }
        }
      ]
    },
    {
      "id": "revert-no-daemon-error",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab revert 5",
          "assert": {
            ".status": "error",
            ".errors | length": { "$gt": 0 },
            ".errors[0].message": { "$contains": "daemon is not attached" }
          }
        }
      ]
    },
    {
      "id": "unpack-no-daemon-error",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab unpack 2",
          "assert": {
            ".status": "error",
            ".errors | length": { "$gt": 0 },
            ".errors[0].message": { "$contains": "daemon is not attached" }
          }
        }
      ]
    },
    {
      "id": "unpack-completely-no-daemon-error",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab unpack 2 --completely",
          "assert": {
            ".status": "error",
            ".errors | length": { "$gt": 0 },
            ".errors[0].message": { "$contains": "daemon is not attached" }
          }
        }
      ]
    },
    {
      "id": "variant-no-daemon-error",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab variant Assets/Prefabs/Base.prefab Assets/Prefabs/BaseVariant.prefab",
          "assert": {
            ".status": "error",
            ".errors | length": { "$gt": 0 },
            ".errors[0].message": { "$contains": "daemon is not attached" }
          }
        }
      ]
    },
    {
      "id": "create-auto-appends-prefab-ext",
      "predict": "pass",
      "steps": [
        {
          "cmd": "prefab create Player Assets/Prefabs/Test",
          "assert": {
            ".status": "error",
            ".errors[0].message": { "$contains": "daemon is not attached" }
          }
        }
      ]
    }
  ]
}
