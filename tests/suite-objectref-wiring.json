{
  "$schema": "../.codex/testcase.schema.json",
  "suite": "objectref-wiring",
  "runner": "dotnet run --project {suite_dir}/../src/unifocl/unifocl.csproj --disable-build-servers -v minimal --",
  "project": "{suite_dir}/../.local/compatcheck-benchmark",
  "mode": "project",
  "cases": [
    {
      "id": "bridge-componentindex-null-fix",
      "predict": "pass",
      "steps": [
        {
          "cmd": "/mutate [{\"op\":\"set_field\",\"target\":\"/Canvas/TitleText\",\"component\":\"Text\",\"field\":\"text\",\"value\":\"Hello\"}]",
          "assert": { ".status": "ok", ".data.allOk": true }
        }
      ]
    },
    {
      "id": "host-mode-scene-ref",
      "predict": "pass",
      "steps": [
        {
          "cmd": "/mutate [{\"op\":\"set_field\",\"target\":\"Assets/Prefabs/MissionConsole.prefab\",\"component\":\"MissionConsoleUI\",\"field\":\"titleText\",\"value\":\"scene:/Canvas/TitleText\"}]",
          "assert": { ".status": "ok", ".data.allOk": true }
        }
      ]
    },
    {
      "id": "host-mode-asset-ref",
      "predict": "pass",
      "steps": [
        {
          "cmd": "/mutate [{\"op\":\"set_field\",\"target\":\"Assets/Prefabs/MissionConsole.prefab\",\"component\":\"MissionConsoleUI\",\"field\":\"icon\",\"value\":\"asset:Assets/Textures/icon.png\"}]",
          "assert": { ".status": "ok", ".data.allOk": true }
        }
      ]
    },
    {
      "id": "host-mode-clear-ref",
      "predict": "pass",
      "steps": [
        {
          "cmd": "/mutate [{\"op\":\"set_field\",\"target\":\"Assets/Prefabs/MissionConsole.prefab\",\"component\":\"MissionConsoleUI\",\"field\":\"titleText\",\"value\":null}]",
          "assert": { ".status": "ok", ".data.allOk": true }
        }
      ]
    },
    {
      "id": "regression-wrong-component-inspected",
      "predict": "pass",
      "steps": [
        {
          "cmd": "/mutate [{\"op\":\"set_field\",\"target\":\"/Canvas/Button\",\"component\":\"Button\",\"field\":\"interactable\",\"value\":\"false\"}]",
          "assert": {
            ".status": "ok",
            ".data.allOk": true,
            ".errors | length": 0
          }
        }
      ]
    }
  ]
}
