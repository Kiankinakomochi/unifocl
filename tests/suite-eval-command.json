{
  "suite": "eval-command",
  "runner": "dotnet run --no-build --project {suite_dir}/../src/unifocl/unifocl.csproj --",
  "project": "{suite_dir}/../.local/compatcheck-benchmark",
  "mode": "project",
  "cases": [
    {
      "id": "eval-compile-error",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"not valid C#!!!\"",
          "assert": {
            ".data.logs": { "$contains": "compilation failed" }
          }
        }
      ]
    },
    {
      "id": "eval-simple-return",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"return Application.productName;\"",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains": "eval: eval" }
          }
        }
      ]
    },
    {
      "id": "eval-void-returns-null",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"Debug.Log(string.Empty);\"",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains": "null" }
          }
        }
      ]
    },
    {
      "id": "eval-async-await",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"await Task.Delay(10, cancellationToken); return 99;\"",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains": "99" }
          }
        }
      ]
    },
    {
      "id": "eval-timeout",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"while(!cancellationToken.IsCancellationRequested){} return 0;\" --timeout 300",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains": "eval: eval" }
          }
        }
      ]
    },
    {
      "id": "eval-dry-run-reverts",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"return 1 + 1;\" --dry-run",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains": "eval: eval-dry-run" }
          }
        }
      ]
    },
    {
      "id": "eval-declarations",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"return new Msg().value;\" --declarations \"public class Msg { public int value = 777; }\"",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains": "777" }
          }
        }
      ]
    },
    {
      "id": "eval-unity-object-serialization",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"return Camera.main;\"",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains": "eval: eval" }
          }
        }
      ]
    },
    {
      "id": "eval-numeric-precision",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"return 3.14159f;\"",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains": "3.14159" }
          }
        }
      ]
    },
    {
      "id": "eval-collection-serialization",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"return new int[]{1,2,3}.Length;\"",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains": "3" }
          }
        }
      ]
    },
    {
      "id": "eval-dictionary-serialization",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"var d = new System.Collections.Generic.Dictionary<string,int>(); d[string.Empty]=1; return d.Count;\"",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0,
            ".data.logs": { "$contains": "1" }
          }
        }
      ]
    }
  ]
}
