{
  "suite": "eval-command",
  "runner": "dotnet run --no-build --project {suite_dir}/../src/unifocl/unifocl.csproj --",
  "project": "{suite_dir}/../.local/compatcheck-benchmark",
  "mode": "project",
  "cases": [
    {
      "id": "eval-compile-error",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"not valid C#!!!\"",
          "assert": {
            ".status": "error",
            ".data.ok": false,
            ".data.message": { "$contains": "compilation failed" }
          }
        }
      ]
    },
    {
      "id": "eval-simple-return",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"return Application.productName;\"",
          "assert": {
            ".status": "success",
            ".data.ok": true,
            ".data.kind": "eval",
            ".data.content": { "$exists": true }
          }
        }
      ]
    },
    {
      "id": "eval-void-returns-null",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"Debug.Log(\\\"hello from eval\\\");\"",
          "assert": {
            ".status": "success",
            ".data.ok": true,
            ".data.content": "null"
          }
        }
      ]
    },
    {
      "id": "eval-async-await",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"await Task.Delay(10, cancellationToken); return \\\"done\\\";\"",
          "assert": {
            ".status": "success",
            ".data.ok": true,
            ".data.content": "done"
          }
        }
      ]
    },
    {
      "id": "eval-timeout",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"while(!cancellationToken.IsCancellationRequested){} return \\\"never\\\";\" --timeout 300",
          "assert": {
            ".status": "error",
            ".data.ok": false,
            ".data.message": { "$contains": "failed" }
          }
        }
      ]
    },
    {
      "id": "eval-dry-run-reverts",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"return Camera.main?.name ?? \\\"no-camera\\\";\" --dry-run",
          "assert": {
            ".status": "success",
            ".data.ok": true,
            ".data.kind": "eval-dry-run",
            ".data.message": { "$contains": "reverted" }
          }
        }
      ]
    },
    {
      "id": "eval-declarations",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"return new Msg().text;\" --declarations \"public class Msg { public string text = \\\"hello\\\"; }\"",
          "assert": {
            ".status": "success",
            ".data.ok": true,
            ".data.content": "hello"
          }
        }
      ]
    },
    {
      "id": "eval-unity-object-serialization",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"return Camera.main;\"",
          "assert": {
            ".status": "success",
            ".data.ok": true,
            ".data.kind": "eval",
            ".data.content": { "$exists": true }
          }
        }
      ]
    },
    {
      "id": "eval-numeric-precision",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"return 3.14159f;\"",
          "assert": {
            ".status": "success",
            ".data.ok": true,
            ".data.content": { "$contains": "3.14159" }
          }
        }
      ]
    },
    {
      "id": "eval-collection-serialization",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"return new int[]{1,2,3};\"",
          "assert": {
            ".status": "success",
            ".data.ok": true,
            ".data.content": { "$contains": "[" }
          }
        }
      ]
    },
    {
      "id": "eval-dictionary-serialization",
      "steps": [
        {
          "cmd": "/open {suite_dir}/../.local/compatcheck-benchmark",
          "assert": {
            ".status": "success",
            ".meta.exitCode": 0
          }
        },
        {
          "cmd": "/eval \"var d = new Dictionary<string,int>(); d[\\\"a\\\"]=1; d[\\\"b\\\"]=2; return d;\"",
          "assert": {
            ".status": "success",
            ".data.ok": true,
            ".data.content": { "$contains": "\"a\"" }
          }
        }
      ]
    }
  ]
}
