{
  "$schema": "../.codex/testcase.schema.json",
  "suite": "mcp-init-discoverability",
  "runner": "python3 {suite_dir}/../scripts/mcp-tool-runner.py",
  "project": "{suite_dir}/../.local/compatcheck-benchmark",
  "mode": "project",
  "cases": [
    {
      "id": "get-categories-no-project-hint",
      "predict": "pass",
      "steps": [
        {
          "cmd": "get_categories",
          "assert": {
            ".status": "ok",
            ".data.manifestLoaded": false,
            ".data.hint": { "$contains": "exec '/open" }
          }
        }
      ]
    },
    {
      "id": "reload-manifest-no-project",
      "predict": "pass",
      "steps": [
        {
          "cmd": "reload_manifest",
          "assert": {
            ".status": "ok",
            ".data.ok": false,
            ".data.message": { "$contains": "No active project" }
          }
        }
      ]
    },
    {
      "id": "workflow-guide-custom-commands-key",
      "predict": "pass",
      "steps": [
        {
          "cmd": "get_agent_workflow_guide",
          "assert": {
            ".status": "ok",
            ".data.custom_commands": { "$exists": true },
            ".data.custom_commands.discovery_flow | length": { "$gte": 1 }
          }
        }
      ]
    },
    {
      "id": "workflow-guide-command-discovery-key",
      "predict": "pass",
      "steps": [
        {
          "cmd": "get_agent_workflow_guide",
          "assert": {
            ".status": "ok",
            ".data.command_discovery": { "$exists": true },
            ".data.command_discovery.lookup_command": { "$exists": true }
          }
        }
      ]
    }
  ]
}
