{
  "$schema": "../.codex/testcase.schema.json",
  "suite": "dryrun-uvc-revert",
  "runner": "dotnet run --project {suite_dir}/../src/unifocl/unifocl.csproj --disable-build-servers -v minimal --",
  "project": "{suite_dir}/../.local/compatcheck-benchmark",
  "mode": "hierarchy",
  "cases": [
    {
      "id": "dryrun-returns-preview",
      "predict": "pass",
      "steps": [
        {
          "cmd": "/mutate --dry-run [{\"op\":\"set_field\",\"target\":\"/Canvas/TitleText\",\"component\":\"Text\",\"field\":\"text\",\"value\":\"DryRunTest\"}]",
          "assert": {
            ".status": "ok",
            ".data.allOk": true,
            ".data.dryRun": true
          }
        }
      ]
    },
    {
      "id": "dryrun-then-real-mutation",
      "predict": "pass",
      "steps": [
        {
          "cmd": "/mutate --dry-run [{\"op\":\"set_field\",\"target\":\"/Canvas/TitleText\",\"component\":\"Text\",\"field\":\"text\",\"value\":\"DryRunTest\"}]",
          "assert": {
            ".status": "ok",
            ".data.allOk": true,
            ".data.dryRun": true
          }
        },
        {
          "cmd": "/mutate [{\"op\":\"set_field\",\"target\":\"/Canvas/TitleText\",\"component\":\"Text\",\"field\":\"text\",\"value\":\"Hello\"}]",
          "assert": {
            ".status": "ok",
            ".data.allOk": true
          }
        }
      ]
    },
    {
      "id": "repeated-dryrun-stable",
      "predict": "pass",
      "steps": [
        {
          "cmd": "/mutate --dry-run [{\"op\":\"set_field\",\"target\":\"/Canvas/TitleText\",\"component\":\"Text\",\"field\":\"text\",\"value\":\"First\"}]",
          "assert": {
            ".status": "ok",
            ".data.allOk": true,
            ".data.dryRun": true
          }
        },
        {
          "cmd": "/mutate --dry-run [{\"op\":\"set_field\",\"target\":\"/Canvas/TitleText\",\"component\":\"Text\",\"field\":\"text\",\"value\":\"Second\"}]",
          "assert": {
            ".status": "ok",
            ".data.allOk": true,
            ".data.dryRun": true
          }
        }
      ]
    },
    {
      "id": "dryrun-toggle-then-real",
      "predict": "pass",
      "steps": [
        {
          "cmd": "/mutate --dry-run [{\"op\":\"toggle_active\",\"target\":\"/Canvas/Button\"}]",
          "assert": {
            ".status": "ok",
            ".data.allOk": true,
            ".data.dryRun": true
          }
        },
        {
          "cmd": "/dump hierarchy",
          "assert": {
            ".status": "ok"
          }
        }
      ]
    }
  ]
}
